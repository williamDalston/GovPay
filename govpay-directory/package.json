{
  "name": "govpay-directory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx scripts/seed-reference.ts",
    "etl:opm": "npx tsx scripts/etl-opm.ts",
    "etl:tx": "npx tsx scripts/etl-state-tx.ts",
